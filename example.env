# PostgreSQL
POSTGRES_USER=personas
POSTGRES_PASSWORD=secret
POSTGRES_DB=personas_db

# URL de conexión para la app Go (usa el nombre del servicio Docker: postgres)
DATABASE_URL=postgres://personas:secret@postgres:5432/personas_db?sslmode=disable

# pgAdmin (variables requeridas por dpage/pgadmin4)
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
